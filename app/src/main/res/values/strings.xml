    <!-- Rust Library Screen -->
    <string name="title_rust_library">Rust Library</string>
    <string name="rust_library_name">librvsystem_monitor.so</string>
    <string name="rust_library_version">Version: v%1$s</string>
    <string name="rust_public_methods">Public methods</string>
    <string name="rust_public_method_detail">Public method detail</string>
    <string name="rust_method_desc_get_version">Returns the semantic version of the native library defined in Cargo.toml.</string>
    <string name="rust_method_desc_get_vulkan">Queries the system Vulkan driver and returns formatted API and Driver versions.</string>
    <string name="rust_method_desc_get_gpu_temp">Reads GPU thermal sensors via kernel sysfs nodes.</string>
    <string name="rust_method_desc_get_memory">Fetches a comprehensive batch of RAM and ZRAM metrics in a single JNI call.</string>
    <string name="rust_method_desc_get_ram">Returns detailed RAM statistics (Total, Available, Cached, etc.).</string>
    <string name="rust_method_desc_get_zram">Returns ZRAM specific metrics including compression ratio and swap usage.</string>
    <string name="rust_method_desc_get_all_freq">Retrieves current clock speeds for all online CPU cores.</string>
    <string name="rust_method_desc_get_core_count">Returns the total number of CPU cores detected by the kernel.</string>
    <string name="rust_method_desc_get_core_freq">Returns specific frequency type (cur, min, max) for a given core ID.</string>
    <string name="rust_method_desc_get_governor">Returns the active CPU scaling governor for the specified core.</string>
    <string name="rust_method_desc_get_cpu_temp">Retrieves the package/composite CPU temperature.</string>
    <string name="rust_method_desc_get_all_temps">Returns an array of temperatures for each individual CPU core.</string>
    <string name="rust_method_desc_get_dynamic">Batched retrieval of temperatures and frequencies for UI synchronization.</string>
    <string name="rust_method_desc_calculate_load">Parses /proc/stat string and calculates the load percentage for total CPU and each core by comparing with the previous state.</string>

